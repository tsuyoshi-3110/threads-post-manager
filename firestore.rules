rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ログイン済みか確認
    function isLogin() {
      return request.auth != null;
    }

    // 自分のドキュメントか確認
    function isOwner(userId) {
      return isLogin() && request.auth.uid == userId;
    }

    // --- users ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- brands ---
    match /brands/{brandId} {
      allow read, update, delete: if isLogin() && resource.data.userId == request.auth.uid;
      allow create: if isLogin() && request.resource.data.userId == request.auth.uid;
    }

    // --- posts ---
    match /posts/{postId} {
      allow read, update, delete: if isLogin() && resource.data.userId == request.auth.uid;
      allow create: if isLogin() && request.resource.data.userId == request.auth.uid;
    }

    // --- products ---
    match /products/{productId} {
      allow read, update, delete: if isLogin() && resource.data.userId == request.auth.uid;
      allow create: if isLogin() && request.resource.data.userId == request.auth.uid;
    }
  }
}
